{
  "name": "disk-monitor-frontend",
  "private": true,
  "version": "1.1.0",
  "description": "A simple and powerful disk storage monitor application.",
  "author": "higashiaka",
  "repository": {
    "type": "git",
    "url": "https://github.com/higashiaka/disk-monitor.git"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"wait-on tcp:5173 && npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "tsc -p electron/tsconfig.json && electron .",
    "build": "tsc && vite build && npm run build:electron",
    "build:electron": "tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --win",
    "dist:portable": "npm run build && electron-builder --win --portable"
  },
  "build": {
    "appId": "com.antigravity.diskmonitor",
    "productName": "Disk Monitor",
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/backend_main.exe",
        "to": "backend/backend_main.exe"
      }
    ]
  },
  "dependencies": {
    "axios": "^1.6.0",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "typescript": "^5.2.2",
    "vite": "^7.3.1",
    "wait-on": "^7.2.0"
  }
}